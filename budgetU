                  <div style={{ fontSize:11, color:C.muted }}>Dépensé ce mois</div>
                  <div style={{ fontSize:28, fontWeight:800, color:C.accent3 }}>{currency}{totalSpent.toFixed(0)}</div>
                  <div style={{ fontSize:10, color:C.muted }}>sur {currency}{totalBudget} budget</div>
                </div>
                <Donut data={donutData} size={74} label={`${currency}${totalSpent.toFixed(0)}`}/>
              </div>
              <ProgressBar value={totalSpent} max={totalBudget} height={7}/>
              <div style={{ display:"flex", gap:8, marginTop:8, flexWrap:"wrap" }}>
                <Badge color={C.accent2}>Épargne: {savingsRate}%</Badge>
                <Badge color={totalSpent>totalBudget?C.accent3:C.accent}>
                  {totalSpent>totalBudget?`Dépassé de ${currency}${(totalSpent-totalBudget).toFixed(0)}`:`${currency}${(totalBudget-totalSpent).toFixed(0)} restants`}
                </Badge>
              </div>
            </>
