// ─── EXPENSES ─────────────────────────────────────────────────
function Expenses({ state, onUpdate }) {
  const { profile, transactions, categories, accounts } = state;
  const currency = profile.currency||"€";
  const [showAdd, setShowAdd] = useState(false);
  const [showCsv, setShowCsv] = useState(false);
  const [editId, setEditId] = useState(null);
  const [csvText, setCsvText] = useState("");
  const [filterCat, setFilterCat] = useState("all");
  const [form, setForm] = useState({ name:"", amount:"", category: categories[0]?.id||"autres", account: accounts[0]?.id||"courant", date: new Date().toISOString().split("T")[0], type:"expense" });

  const suggested = autoClassify(form.name, categories);

  const filtered = filterCat==="all" ? transactions : transactions.filter(t=>t.category===filterCat);

  const now = new Date();
  const monthKey = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,"0")}`;
  const monthTx = transactions.filter(t=>t.date.startsWith(monthKey)&&t.amount<0);
  const byCategory = {};
  monthTx.forEach(t=>{ byCategory[t.category]=(byCategory[t.category]||0)+Math.abs(t.amount); });
  const totalSpent = Object.values(byCategory).reduce((s,v)=>s+v,0);
  const donutData = Object.entries(byCategory).map(([id,val])=>({ color:categories.find(c=>c.id===id)?.color||C.muted, value:val }));

  function addTx() {
    if(!form.name||!form.amount) return;
    const sign = form.type==="expense" ? -1 : 1;
    const tx = { id:Date.now(), name:form.name, amount:sign*Math.abs(parseFloat(form.amount)), date:form.date, category:form.category, account:form.account };
    // Update account balance
    const newAccounts = state.accounts.map(a=>a.id===form.account?{...a,balance:a.balance+tx.amount}:a);
    onUpdate({ transactions:[tx,...transactions], accounts:newAccounts });
    setForm(p=>({...p,name:"",amount:""}));
    setShowAdd(false);
  }

  function deleteTx(id) {
    const tx = transactions.find(t=>t.id===id);
    if(!tx) return;
    const newAccounts = state.accounts.map(a=>a.id===tx.account?{...a,balance:a.balance-tx.amount}:a);
    onUpdate({ transactions:transactions.filter(t=>t.id!==id), accounts:newAccounts });
  }

  function changeCat(id, newCat) {
    onUpdate({ transactions:transactions.map(t=>t.id===id?{...t,category:newCat}:t) });
    setEditId(null);
  }

  function importCsv() {
    const lines = csvText.trim().split("\n").slice(1);
    const imported = lines.map((line,i)=>{
      const [name,amount,date] = line.split(",").map(s=>s.trim());
      const amt = parseFloat(amount);
      return { id:Date.now()+i, name:name||"Transaction", amount:isNaN(amt)?0:amt, date:date||new Date().toISOString().split("T")[0], category:autoClassify(name||"",categories), account:accounts[0]?.id||"courant" };
    }).filter(t=>t.amount!==0);
    onUpdate({ transactions:[...imported,...transactions] });
    setCsvText(""); setShowCsv(false);
  }

  return (
    <div style={{ padding:"0 0 80px" }}>
      <div style={{ padding:"20px 16px 12px", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <div>
          <div style={{ fontSize:22, fontWeight:800 }}>Dépenses</div>
          <div style={{ fontSize:11, color:C.muted }}>{now.toLocaleDateString("fr-FR",{month:"long",year:"numeric"})}</div>
        </div>
        <div style={{ display:"flex", gap:8 }}>
          <button onClick={()=>setShowCsv(true)} style={{ background:C.card2, border:`1px solid ${C.border}`, color:C.muted, borderRadius:10, padding:"7px 10px", fontSize:11, cursor:"pointer" }}>📂 CSV</button>
          <button onClick={()=>setShowAdd(true)} style={{ background:C.accent, color:"#0d0f14", borderRadius:10, padding:"7px 14px", fontSize:12, fontWeight:800, border:"none", cursor:"pointer" }}>+ Ajouter</button>
        </div>
      </div>

      <div style={{ padding:"0 14px", display:"flex", flexDirection:"column", gap:12 }}>
        {/* Donut summary */}
        {totalSpent>0 ? (
          <Card>
            <div style={{ display:"flex", alignItems:"center", gap:14 }}>
              <Donut data={donutData} size={86}/>
              <div style={{ flex:1, display:"flex", flexDirection:"column", gap:7 }}>
                {Object.entries(byCategory).map(([catId,val])=>{
                  const cat=categories.find(c=>c.id===catId)||{label:catId,icon:"📦",color:C.muted};
                  return (
                    <div key={catId} style={{ display:"flex", alignItems:"center", gap:6 }}>
                      <div style={{ width:7, height:7, borderRadius:"50%", background:cat.color, flexShrink:0 }}/>
                      <span style={{ flex:1, fontSize:10, color:C.muted }}>{cat.label}</span>
                      <span style={{ fontSize:11, fontWeight:700, color:cat.color }}>{currency}{val.toFixed(0)}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          </Card>
        ) : (
          <Card style={{ textAlign:"center", padding:24 }}>
            <div style={{ fontSize:32, marginBottom:8 }}>📊</div>
            <div style={{ fontSize:13, color:C.muted }}>Aucune dépense ce mois</div>
          </Card>
        )}

        {/* Category budgets */}
        {totalSpent>0 && (
          <Card>
            <div style={{ fontSize:13, fontWeight:700, marginBottom:12 }}>Budgets</div>
            <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
              {categories.filter(c=>byCategory[c.id]).map(c=>{
                const spent=byCategory[c.id]||0, pct=c.budget>0?(spent/c.budget)*100:0;
                return (
                  <div key={c.id}>
                    <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:5 }}>
                      <span style={{ fontSize:14 }}>{c.icon}</span>
                      <span style={{ flex:1, fontSize:12 }}>{c.label}</span>
                      <span style={{ fontSize:11, color:pct>=100?C.accent3:C.muted }}>{currency}{spent.toFixed(0)}/{currency}{c.budget}</span>
                      <Badge color={pct>=100?C.accent3:pct>=80?C.accent4:C.accent2}>{Math.round(pct)}%</Badge>
                    </div>
                    <ProgressBar value={spent} max={c.budget} color={c.color} height={5}/>
                  </div>
                );
              })}
            </div>
          </Card>
        )}

        {/* Filter + list */}
        <div>
          <div style={{ display:"flex", gap:6, overflowX:"auto", paddingBottom:8 }}>
            <div onClick={()=>setFilterCat("all")} style={{ padding:"5px 12px", borderRadius:99, fontSize:11, fontWeight:600, cursor:"pointer", flexShrink:0, background:filterCat==="all"?C.accent:C.card, color:filterCat==="all"?"#0d0f14":C.muted, border:`1px solid ${filterCat==="all"?C.accent:C.border}` }}>Tout</div>
            {categories.map(c=>(
              <div key={c.id} onClick={()=>setFilterCat(c.id)} style={{ padding:"5px 12px", borderRadius:99, fontSize:11, fontWeight:600, cursor:"pointer", flexShrink:0, background:filterCat===c.id?c.color:C.card, color:filterCat===c.id?"#0d0f14":C.muted, border:`1px solid ${filterCat===c.id?c.color:C.border}` }}>{c.icon}</div>
            ))}
          </div>

          {filtered.length===0 ? (
            <Card style={{ textAlign:"center", padding:20 }}>
              <div style={{ color:C.muted, fontSize:13 }}>Aucune transaction</div>
            </Card>
          ) : (
            <Card>
              <div style={{ display:"flex", flexDirection:"column", gap:2 }}>
                {filtered.map(t=>{
                  const cat=categories.find(c=>c.id===t.category)||{icon:"📦",color:C.muted,label:"Autres"};
                  return (
                    <div key={t.id} style={{ display:"flex", alignItems:"center", gap:10, padding:"9px 0", borderBottom:`1px solid ${C.border}` }}>
                      <div style={{ width:34, height:34, borderRadius:10, background:cat.color+"22", display:"flex", alignItems:"center", justifyContent:"center", fontSize:15, flexShrink:0 }}>{cat.icon}</div>
                      <div style={{ flex:1, minWidth:0 }}>
                        <div style={{ fontSize:12, fontWeight:500, whiteSpace:"nowrap", overflow:"hidden", textOverflow:"ellipsis" }}>{t.name}</div>
                        <div style={{ fontSize:9, color:C.muted }}>{t.date}</div>
                      </div>
                      {editId===t.id ? (
                        <select onChange={e=>changeCat(t.id,e.target.value)} style={{ background:C.card2, color:C.text, border:`1px solid ${C.border}`, borderRadius:8, fontSize:10, padding:"3px 5px" }}>
                          {categories.map(c=><option key={c.id} value={c.id}>{c.icon} {c.label}</option>)}
                        </select>
                      ) : (
                        <span onClick={()=>setEditId(t.id)} style={{ fontSize:9, color:C.muted, cursor:"pointer", textDecoration:"underline", flexShrink:0 }}>{cat.icon} {cat.label}</span>
                      )}
                      <div style={{ fontSize:13, fontWeight:800, color:t.amount<0?C.accent3:C.accent2, minWidth:50, textAlign:"right" }}>
                        {t.amount<0?"−":"+"}{ currency}{Math.abs(t.amount).toFixed(0)}
                      </div>
                      <span onClick={()=>deleteTx(t.id)} style={{ color:C.accent3, cursor:"pointer", fontSize:12, padding:"0 2px", flexShrink:0 }}>🗑</span>
                    </div>
                  );
                })}
              </div>
            </Card>
          )}
        </div>
      </div>

      {/* Add modal */}
      {showAdd && (
        <Modal title="Nouvelle transaction" onClose={()=>setShowAdd(false)}>
          <Field label="Type">
            <div style={{ display:"flex", gap:8 }}>
              {[["expense","Dépense",C.accent3],["income","Revenu",C.accent2]].map(([v,l,col])=>(
                <div key={v} onClick={()=>setForm(p=>({...p,type:v}))} style={{ flex:1, padding:"9px 0", borderRadius:10, textAlign:"center", background:form.type===v?col+"22":C.card2, border:`1px solid ${form.type===v?col:C.border}`, color:form.type===v?col:C.muted, fontSize:13, fontWeight:700, cursor:"pointer" }}>{l}</div>
              ))}
            </div>
          </Field>
          <Field label="Nom">
            <TextInput value={form.name} onChange={e=>setForm(p=>({...p,name:e.target.value}))} placeholder="Ex: Courses Lidl"/>
          </Field>
          <Field label={`Montant (${currency})`}>
            <TextInput type="number" value={form.amount} onChange={e=>setForm(p=>({...p,amount:e.target.value}))} placeholder="0.00"/>
          </Field>
          <Field label="Date">
            <TextInput type="date" value={form.date} onChange={e=>setForm(p=>({...p,date:e.target.value}))}/>
          </Field>
          <Field label="Catégorie">
            <select value={form.category} onChange={e=>setForm(p=>({...p,category:e.target.value}))} style={{ width:"100%", background:C.card2, border:`1px solid ${C.border}`, color:C.text, borderRadius:10, padding:"11px 13px", fontSize:14 }}>
              {categories.map(c=><option key={c.id} value={c.id}>{c.icon} {c.label}</option>)}
            </select>
          </Field>
          {accounts.length>1 && (
            <Field label="Compte">
              <select value={form.account} onChange={e=>setForm(p=>({...p,account:e.target.value}))} style={{ width:"100%", background:C.card2, border:`1px solid ${C.border}`, color:C.text, borderRadius:10, padding:"11px 13px", fontSize:14 }}>
                {accounts.map(a=><option key={a.id} value={a.id}>{a.icon} {a.label}</option>)}
              </select>
            </Field>
          )}
          {form.name && autoClassify(form.name,categories)!==form.category && (
            <div style={{ background:C.card2, borderRadius:10, padding:"8px 12px", marginBottom:14, fontSize:11, color:C.muted }}>
              🤖 Suggestion IA : <strong style={{ color:C.accent }}>{categories.find(c=>c.id===suggested)?.icon} {categories.find(c=>c.id===suggested)?.label}</strong>
              <span onClick={()=>setForm(p=>({...p,category:suggested}))} style={{ color:C.accent2, cursor:"pointer", marginLeft:8, textDecoration:"underline" }}>Appliquer</span>
            </div>
          )}
          <div style={{ display:"flex", gap:10 }}>
            <SecBtn onClick={()=>setShowAdd(false)} style={{ flex:1 }}>Annuler</SecBtn>
            <PrimaryBtn onClick={addTx} disabled={!form.name||!form.amount} style={{ flex:2 }}>Ajouter</PrimaryBtn>
          </div>
        </Modal>
      )}

      {/* CSV modal */}
      {showCsv && (
        <Modal title="📂 Import CSV" onClose={()=>setShowCsv(false)}>
          <div style={{ fontSize:11, color:C.muted, marginBottom:12 }}>Format : nom, montant, date (ligne d'en-tête ignorée)</div>
          <div style={{ background:C.card2, borderRadius:10, padding:10, marginBottom:12, fontSize:11, color:C.muted, fontFamily:"monospace" }}>
            nom,montant,date<br/>Lidl,-42.50,2026-03-01<br/>Salaire,1200,2026-03-05
          </div>
          <textarea value={csvText} onChange={e=>setCsvText(e.target.value)} placeholder="Collez votre CSV ici…"
            style={{ width:"100%", height:100, background:C.card2, border:`1px solid ${C.border}`, color:C.text, borderRadius:10, padding:12, fontSize:12, resize:"none", fontFamily:"monospace" }}/>
          <div style={{ display:"flex", gap:10, marginTop:12 }}>
            <SecBtn onClick={()=>setShowCsv(false)} style={{ flex:1 }}>Annuler</SecBtn>
            <PrimaryBtn onClick={importCsv} disabled={!csvText.trim()} style={{ flex:2 }}>Importer</PrimaryBtn>
          </div>
        </Modal>
      )}
    </div>
  );
}

// ─── FORECAST ─────────────────────────────────────────────────
function Forecast({ state }) {
  const { profile, transactions, categories } = state;
  const currency = profile.currency||"€";
  const income = parseFloat(profile.income)||0;
  const now = new Date();
  const day = now.getDate();
  const daysInMonth = new Date(now.getFullYear(),now.getMonth()+1,0).getDate();
  const monthKey = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,"0")}`;
  const expenses = transactions.filter(t=>t.date.startsWith(monthKey)&&t.amount<0);
  const totalSpent = Math.abs(expenses.reduce((s,t)=>s+t.amount,0));
  const dailyRate = day>0?totalSpent/day:0;
  const projected = dailyRate*daysInMonth;
  const projBalance = income-projected;
  const [sim, setSim] = useState({});

  const simExtra = Object.values(sim).reduce((s,v)=>s+v,0);
  const simBalance = projBalance - simExtra;

  if(income===0) return (
    <div style={{ padding:"0 0 80px" }}>
      <div style={{ padding:"20px 16px 12px" }}>
        <div style={{ fontSize:22, fontWeight:800 }}>Prévisions 📈</div>
      </div>
      <div style={{ padding:"0 14px" }}>
        <Card style={{ textAlign:"center", padding:28 }}>
          <div style={{ fontSize:32, marginBottom:10 }}>⚙️</div>
          <div style={{ fontSize:14, color:C.muted, lineHeight:1.7 }}>Configurez votre revenu mensuel dans les Réglages pour voir les prévisions.</div>
        </Card>
      </div>
    </div>
  );

  return (
    <div style={{ padding:"0 0 80px" }}>
      <div style={{ padding:"20px 16px 12px" }}>
        <div style={{ fontSize:22, fontWeight:800 }}>Prévisions 📈</div>
        <div style={{ fontSize:11, color:C.muted }}>Projection fin de mois · Jour {day}/{daysInMonth}</div>
      </div>

      <div style={{ padding:"0 14px", display:"flex", flexDirection:"column", gap:12 }}>
        <Card style={{ background:projBalance>=0?"linear-gradient(135deg,#0d1f0d,#0a1a14)":"linear-gradient(135deg,#1f0d0d,#1a0a0a)", border:`1px solid ${projBalance>=0?C.accent2:C.accent3}44` }}>
          <div style={{ fontSize:12, color:C.muted, marginBottom:4 }}>Solde projeté fin de mois</div>
          <div style={{ fontSize:38, fontWeight:800, color:projBalance>=0?C.accent2:C.accent3 }}>
            {projBalance>=0?"+":""}{currency}{projBalance.toFixed(0)}
          </div>
          <div style={{ fontSize:11, color:C.muted, marginTop:4 }}>
            Revenu {currency}{income} — Projection dépenses {currency}{projected.toFixed(0)}
          </div>
          <div style={{ marginTop:14 }}>
            <ProgressBar value={projected} max={income} color={projBalance>=0?C.accent2:C.accent3} height={7}/>
            <div style={{ display:"flex", justifyContent:"space-between", marginTop:6, fontSize:10, color:C.muted }}>
              <span>Dépensé: {currency}{totalSpent.toFixed(0)}</span>
              <span>Rythme: {currency}{dailyRate.toFixed(0)}/jour</span>
            </div>
          </div>
        </Card>

        {/* Simulator */}
        <Card>
          <div style={{ fontSize:13, fontWeight:700, marginBottom:4 }}>🎮 Simulateur</div>
          <div style={{ fontSize:11, color:C.muted, marginBottom:14 }}>Si j'augmente / réduis une catégorie…</div>
          {categories.filter(c=>c.budget>0).slice(0,4).map(c=>(
            <div key={c.id} style={{ marginBottom:14 }}>
              <div style={{ display:"flex", justifyContent:"space-between", marginBottom:6 }}>
                <span style={{ fontSize:12 }}>{c.icon} {c.label}</span>
                <span style={{ fontSize:12, color:(sim[c.id]||0)>0?C.accent3:C.accent2, fontWeight:700 }}>
                  {(sim[c.id]||0)>=0?"+":""}{currency}{sim[c.id]||0}
                </span>
              </div>
              <input type="range" min="-100" max="200" step="10" value={sim[c.id]||0}
                onChange={e=>setSim(p=>({...p,[c.id]:parseInt(e.target.value)}))}
                style={{ width:"100%", accentColor:c.color }}/>
            </div>
          ))}
          <div style={{ background:simBalance>=0?"rgba(90,245,184,0.1)":"rgba(245,90,143,0.1)", border:`1px solid ${simBalance>=0?C.accent2:C.accent3}44`, borderRadius:12, padding:14, textAlign:"center" }}>
            <div style={{ fontSize:11, color:C.muted }}>Solde simulé fin de mois</div>
            <div style={{ fontSize:30, fontWeight:800, color:simBalance>=0?C.accent2:C.accent3 }}>
              {simBalance>=0?"+":""}{currency}{simBalance.toFixed(0)}
            </div>
            {simExtra!==0 && <div style={{ fontSize:11, color:C.muted, marginTop:4 }}>{simExtra>0?`+${currency}${simExtra} de dépenses`:`−${currency}${Math.abs(simExtra)} d'économies`}</div>}
          </div>
        </Card>

        {totalSpent===0 && (
          <Card style={{ textAlign:"center", padding:20, border:`1px dashed ${C.border2}` }}>
            <div style={{ color:C.muted, fontSize:13 }}>Ajoutez des dépenses pour voir les projections en temps réel.</div>
          </Card>
        )}
      </div>
    </div>
  );
}

// ─── GOALS ────────────────────────────────────────────────────
function Goals({ state, onUpdate }) {
  const { profile, goals } = state;
  const currency = profile.currency||"€";
  const [showAdd, setShowAdd] = useState(false);
  const [form, setForm] = useState({ name:"", target:"", saved:"0", monthly:"", icon:"🎯", color:C.accent });

  function addGoal() {
    if(!form.name||!form.target) return;
    const newGoal = { id:Date.now(), name:form.name, target:parseFloat(form.target), saved:parseFloat(form.saved)||0, monthly:parseFloat(form.monthly)||0, icon:form.icon, color:form.color };
    onUpdate({ goals:[...goals, newGoal] });
    setForm({ name:"", target:"", saved:"0", monthly:"", icon:"🎯", color:C.accent });
    setShowAdd(false);
  }

  function addMonthly(id) {
    onUpdate({ goals:goals.map(g=>g.id===id?{...g,saved:Math.min(g.target,g.saved+g.monthly)}:g) });
  }

  function deleteGoal(id) { onUpdate({ goals:goals.filter(g=>g.id!==id) }); }

  return (
    <div style={{ padding:"0 0 80px" }}>
      <div style={{ padding:"20px 16px 12px", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <div>
          <div style={{ fontSize:22, fontWeight:800 }}>Objectifs 🎯</div>
          <div style={{ fontSize:11, color:C.muted }}>Suivi de vos épargnes</div>
        </div>
        <button onClick={()=>setShowAdd(true)} style={{ background:C.accent, color:"#0d0f14", borderRadius:10, padding:"7px 14px", fontSize:12, fontWeight:800, border:"none" }}>+ Nouveau</button>
      </div>

      <div style={{ padding:"0 14px", display:"flex", flexDirection:"column", gap:12 }}>
        {goals.length===0 ? (
          <Card style={{ textAlign:"center", padding:32, border:`1px dashed ${C.border2}` }}>
            <div style={{ fontSize:40, marginBottom:12 }}>🎯</div>
            <div style={{ fontSize:15, fontWeight:700, marginBottom:8 }}>Aucun objectif</div>
            <div style={{ fontSize:13, color:C.muted, marginBottom:18 }}>Créez votre premier objectif d'épargne !</div>
            <button onClick={()=>setShowAdd(true)} style={{ background:C.accent, color:"#0d0f14", border:"none", borderRadius:10, padding:"9px 20px", fontSize:13, fontWeight:800, cursor:"pointer" }}>Créer un objectif</button>
          </Card>
        ) : (
          <>
            <div style={{ display:"flex", gap:8 }}>
              {[
                {l:"Épargné",  v:`${currency}${goals.reduce((s,g)=>s+g.saved,0).toFixed(0)}`, c:C.accent2},
                {l:"Objectif", v:`${currency}${goals.reduce((s,g)=>s+g.target,0).toFixed(0)}`, c:C.muted},
                {l:"Actifs",   v:goals.length, c:C.accent},
              ].map(s=>(
                <Card key={s.l} style={{ flex:1, padding:12, textAlign:"center" }}>
                  <div style={{ fontSize:17, fontWeight:800, color:s.c }}>{s.v}</div>
                  <div style={{ fontSize:9, color:C.muted, marginTop:2 }}>{s.l}</div>
                </Card>
              ))}
            </div>
            {goals.map(g=>{
              const pct=g.target>0?Math.min(100,(g.saved/g.target)*100):0;
              const remaining=g.target-g.saved;
              const months=g.monthly>0?Math.ceil(remaining/g.monthly):null;
              return (
                <Card key={g.id}>
                  <div style={{ display:"flex", alignItems:"center", gap:12, marginBottom:14 }}>
                    <div style={{ width:48, height:48, borderRadius:14, background:g.color+"20", display:"flex", alignItems:"center", justifyContent:"center", fontSize:22 }}>{g.icon}</div>
                    <div style={{ flex:1 }}>
                      <div style={{ fontSize:15, fontWeight:700 }}>{g.name}</div>
                      <div style={{ fontSize:11, color:C.muted }}>{months?`~${months} mois restants`:"Pas de versement mensuel"}</div>
                    </div>
                    <div style={{ textAlign:"right" }}>
                      <div style={{ fontSize:17, fontWeight:800, color:g.color }}>{currency}{g.saved.toFixed(0)}</div>
                      <div style={{ fontSize:11, color:C.muted }}>/ {currency}{g.target}</div>
                    </div>
                    <span onClick={()=>deleteGoal(g.id)} style={{ color:C.accent3, cursor:"pointer", fontSize:13 }}>🗑</span>
                  </div>
                  <div style={{ position:"relative", marginBottom:10 }}>
                    <ProgressBar value={g.saved} max={g.target} color={g.color} height={14}/>
                    <div style={{ position:"absolute", top:"50%", left:`${Math.min(pct,93)}%`, transform:"translate(-50%,-50%)" }}>
                      <span style={{ background:g.color, color:"#0d0f14", fontSize:9, fontWeight:800, padding:"1px 5px", borderRadius:99 }}>{Math.round(pct)}%</span>
                    </div>
                  </div>
                  <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center" }}>
                    <span style={{ fontSize:11, color:C.muted }}>Reste {currency}{remaining.toFixed(0)}</span>
                    {g.monthly>0 && (
                      <button onClick={()=>addMonthly(g.id)} style={{ background:g.color+"20", border:`1px solid ${g.color}44`, color:g.color, borderRadius:99, padding:"5px 14px", fontSize:11, fontWeight:700, cursor:"pointer" }}>
                        +{currency}{g.monthly} ce mois ✓
                      </button>
                    )}
                  </div>
                </Card>
              );
            })}
          </>
        )}
      </div>

      {showAdd && (
        <Modal title="Nouvel objectif" onClose={()=>setShowAdd(false)}>
          <Field label="Icône">
            <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
              {ICONS_GOAL.map(ic=><div key={ic} onClick={()=>setForm(p=>({...p,icon:ic}))} style={{ width:36, height:36, borderRadius:10, background:form.icon===ic?C.accent+"30":C.card2, border:`1px solid ${form.icon===ic?C.accent:C.border}`, display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, cursor:"pointer" }}>{ic}</div>)}
            </div>
          </Field>
          <Field label="Couleur">
            <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
              {PALETTE.map(col=><div key={col} onClick={()=>setForm(p=>({...p,color:col}))} style={{ width:28, height:28, borderRadius:"50%", background:col, border:`3px solid ${form.color===col?"#fff":"transparent"}`, cursor:"pointer" }}/>)}
            </div>
          </Field>
          <Field label="Nom de l'objectif"><TextInput value={form.name} onChange={e=>setForm(p=>({...p,name:e.target.value}))} placeholder="Ex: Voyage Japon"/></Field>
          <Field label={`Montant cible (${currency})`}><TextInput type="number" value={form.target} onChange={e=>setForm(p=>({...p,target:e.target.value}))} placeholder="2000"/></Field>
          <Field label={`Déjà épargné (${currency})`}><TextInput type="number" value={form.saved} onChange={e=>setForm(p=>({...p,saved:e.target.value}))} placeholder="0"/></Field>
          <Field label={`Versement mensuel (${currency})`}><TextInput type="number" value={form.monthly} onChange={e=>setForm(p=>({...p,monthly:e.target.value}))} placeholder="150"/></Field>
          <div style={{ display:"flex", gap:10 }}>
            <SecBtn onClick={()=>setShowAdd(false)} style={{ flex:1 }}>Annuler</SecBtn>
            <PrimaryBtn onClick={addGoal} disabled={!form.name||!form.target} style={{ flex:2 }}>Créer</PrimaryBtn>
          </div>
        </Modal>
      )}
    </div>
  );
}

// ─── SETTINGS ─────────────────────────────────────────────────
function Settings({ state, onUpdate, onReset }) {
  const { profile, categories, accounts } = state;
  const [tab, setTab] = useState("profile");
  const [showAddCat, setShowAddCat] = useState(false);
  const [showAddAcc, setShowAddAcc] = useState(false);
  const [catForm, setCatForm] = useState({ label:"", icon:"📦", color:C.accent, budget:"" });
  const [accForm, setAccForm] = useState({ label:"", icon:"💳", balance:"", color:C.accent });
  const [showConfirmReset, setShowConfirmReset] = useState(false);

  function updateProfile(key, val) { onUpdate({ profile:{ ...profile, [key]:val } }); }
  function updateCat(id, key, val) { onUpdate({ categories:categories.map(c=>c.id===id?{...c,[key]:val}:c) }); }
  function deleteCat(id) { onUpdate({ categories:categories.filter(c=>c.id!==id) }); }
  function addCat() {
    if(!catForm.label) return;
    onUpdate({ categories:[...categories,{ id:Date.now().toString(), ...catForm, budget:parseFloat(catForm.budget)||0 }] });
    setCatForm({ label:"", icon:"📦", color:C.accent, budget:"" });
    setShowAddCat(false);
  }
  function updateAcc(id, key, val) { onUpdate({ accounts:accounts.map(a=>a.id===id?{...a,[key]:val}:a) }); }
  function deleteAcc(id) { onUpdate({ accounts:accounts.filter(a=>a.id!==id) }); }
  function addAcc() {
    if(!accForm.label) return;
    onUpdate({ accounts:[...accounts,{ id:Date.now().toString(), ...accForm, balance:parseFloat(accForm.balance)||0 }] });
    setAccForm({ label:"", icon:"💳", balance:"", color:C.accent });
    setShowAddAcc(false);
  }

  const TABS = [["profile","👤 Profil"],["categories","🏷 Catégories"],["accounts","🏦 Comptes"],["danger","⚠️ Données"]];

  return (
    <div style={{ padding:"0 0 80px" }}>
      <div style={{ padding:"20px 16px 12px" }}>
        <div style={{ fontSize:22, fontWeight:800 }}>Réglages ⚙️</div>
      </div>

      {/* Tabs */}
      <div style={{ display:"flex", gap:6, padding:"0 14px 14px", overflowX:"auto" }}>
        {TABS.map(([id,label])=>(
          <div key={id} onClick={()=>setTab(id)} style={{ padding:"6px 14px", borderRadius:99, fontSize:11, fontWeight:600, cursor:"pointer", flexShrink:0, background:tab===id?C.accent:C.card, color:tab===id?"#0d0f14":C.muted, border:`1px solid ${tab===id?C.accent:C.border}` }}>{label}</div>
        ))}
      </div>

      <div style={{ padding:"0 14px", display:"flex", flexDirection:"column", gap:12 }}>
        {/* PROFILE TAB */}
        {tab==="profile" && (
          <Card>
            <div style={{ fontSize:13, fontWeight:700, marginBottom:14 }}>Informations personnelles</div>
            <Field label="Prénom"><TextInput value={profile.name} onChange={e=>updateProfile("name",e.target.value)} placeholder="Votre prénom"/></Field>
            <Field label="Revenu mensuel"><TextInput type="number" value={profile.income} onChange={e=>updateProfile("income",e.target.value)} placeholder="Ex: 1200"/></Field>
            <Field label="Devise">
              <select value={profile.currency||"€"} onChange={e=>updateProfile("currency",e.target.value)} style={{ width:"100%", background:C.card2, border:`1px solid ${C.border}`, color:C.text, borderRadius:10, padding:"11px 13px", fontSize:14 }}>
                {["€","$","£","CHF","MAD","XOF","DZD","TND"].map(c=><option key={c} value={c}>{c}</option>)}
              </select>
            </Field>
          </Card>
        )}

        {/* CATEGORIES TAB */}
        {tab==="categories" && (
          <>
            <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
              {categories.map(c=>(
                <Card key={c.id} style={{ padding:12 }}>
                  <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                    <div style={{ fontSize:20 }}>{c.icon}</div>
                    <div style={{ flex:1 }}>
                      <input value={c.label} onChange={e=>updateCat(c.id,"label",e.target.value)} style={{ background:"transparent", border:"none", color:C.text, fontSize:13, fontWeight:600, width:"100%" }}/>
                    </div>
                    <div style={{ display:"flex", alignItems:"center", gap:6 }}>
                      <span style={{ fontSize:11, color:C.muted }}>{profile.currency||"€"}</span>
                      <input type="number" value={c.budget} onChange={e=>updateCat(c.id,"budget",parseFloat(e.target.value)||0)} style={{ width:60, background:C.card2, border:`1px solid ${C.border}`, color:C.accent, borderRadius:8, padding:"4px 7px", fontSize:12, fontWeight:700, textAlign:"right" }}/>
                    </div>
                    <span onClick={()=>deleteCat(c.id)} style={{ color:C.accent3, cursor:"pointer", fontSize:13 }}>🗑</span>
                  </div>
                  <div style={{ display:"flex", gap:6, marginTop:10, flexWrap:"wrap" }}>
                    {PALETTE.map(col=><div key={col} onClick={()=>updateCat(c.id,"color",col)} style={{ width:22, height:22, borderRadius:"50%", background:col, border:`2px solid ${c.color===col?"#fff":"transparent"}`, cursor:"pointer" }}/>)}
                  </div>
                </Card>
              ))}
            </div>
            <button onClick={()=>setShowAddCat(true)} style={{ width:"100%", background:"transparent", border:`1px dashed ${C.border2}`, color:C.muted, borderRadius:12, padding:12, fontSize:13, cursor:"pointer" }}>+ Nouvelle catégorie</button>
          </>
        )}

        {/* ACCOUNTS TAB */}
        {tab==="accounts" && (
          <>
            <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
              {accounts.map(a=>(
                <Card key={a.id} style={{ padding:12 }}>
                  <div style={{ display:"flex", alignItems:"center", gap:10, marginBottom:8 }}>
                    <div style={{ fontSize:20 }}>{a.icon}</div>
                    <input value={a.label} onChange={e=>updateAcc(a.id,"label",e.target.value)} style={{ flex:1, background:"transparent", border:"none", color:C.text, fontSize:13, fontWeight:600 }}/>
                    <span onClick={()=>deleteAcc(a.id)} style={{ color:C.accent3, cursor:"pointer", fontSize:13 }}>🗑</span>
                  </div>
                  <div style={{ display:"flex", alignItems:"center", gap:8 }}>
                    <span style={{ fontSize:11, color:C.muted }}>Solde actuel :</span>
                    <input type="number" value={a.balance} onChange={e=>updateAcc(a.id,"balance",parseFloat(e.target.value)||0)} style={{ flex:1, background:C.card2, border:`1px solid ${C.border}`, color:C.accent, borderRadius:8, padding:"6px 10px", fontSize:13, fontWeight:700 }}/>
                    <span style={{ fontSize:12, color:C.muted }}>{profile.currency||"€"}</span>
                  </div>
                </Card>
              ))}
            </div>
            <button onClick={()=>setShowAddAcc(true)} style={{ width:"100%", background:"transparent", border:`1px dashed ${C.border2}`, color:C.muted, borderRadius:12, padding:12, fontSize:13, cursor:"pointer" }}>+ Nouveau compte</button>
          </>
        )}

        {/* DANGER TAB */}
        {tab==="danger" && (
          <Card style={{ border:`1px solid ${C.accent3}44` }}>
            <div style={{ fontSize:13, fontWeight:700, color:C.accent3, marginBottom:12 }}>⚠️ Zone de danger</div>
            <div style={{ fontSize:12, color:C.muted, marginBottom:16, lineHeight:1.6 }}>Ces actions sont irréversibles. Vos données seront définitivement supprimées.</div>
            <button onClick={()=>onUpdate({ transactions:[] })} style={{ width:"100%", background:"rgba(245,90,143,0.1)", border:`1px solid ${C.accent3}44`, color:C.accent3, borderRadius:12, padding:12, fontSize:13, fontWeight:700, cursor:"pointer", marginBottom:8 }}>
              🗑 Effacer toutes les transactions
            </button>
            <button onClick={()=>onUpdate({ goals:[] })} style={{ width:"100%", background:"rgba(245,90,143,0.1)", border:`1px solid ${C.accent3}44`, color:C.accent3, borderRadius:12, padding:12, fontSize:13, fontWeight:700, cursor:"pointer", marginBottom:8 }}>
              🗑 Effacer tous les objectifs
            </button>
            <button onClick={()=>setShowConfirmReset(true)} style={{ width:"100%", background:C.accent3, color:"#fff", border:"none", borderRadius:12, padding:12, fontSize:13, fontWeight:800, cursor:"pointer" }}>
              💥 Réinitialiser l'application
            </button>
          </Card>
        )}
      </div>

      {/* Add category modal */}
      {showAddCat && (
        <Modal title="Nouvelle catégorie" onClose={()=>setShowAddCat(false)}>
          <Field label="Icône">
            <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
              {ICONS_CAT.map(ic=><div key={ic} onClick={()=>setCatForm(p=>({...p,icon:ic}))} style={{ width:36, height:36, borderRadius:10, background:catForm.icon===ic?C.accent+"30":C.card2, border:`1px solid ${catForm.icon===ic?C.accent:C.border}`, display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, cursor:"pointer" }}>{ic}</div>)}
            </div>
          </Field>
          <Field label="Couleur">
            <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
              {PALETTE.map(col=><div key={col} onClick={()=>setCatForm(p=>({...p,color:col}))} style={{ width:28, height:28, borderRadius:"50%", background:col, border:`3px solid ${catForm.color===col?"#fff":"transparent"}`, cursor:"pointer" }}/>)}
            </div>
          </Field>
          <Field label="Nom"><TextInput value={catForm.label} onChange={e=>setCatForm(p=>({...p,label:e.target.value}))} placeholder="Ex: Voyages"/></Field>
          <Field label={`Budget mensuel (${profile.currency||"€"})`}><TextInput type="number" value={catForm.budget} onChange={e=>setCatForm(p=>({...p,budget:e.target.value}))} placeholder="200"/></Field>
          <div style={{ display:"flex", gap:10 }}>
            <SecBtn onClick={()=>setShowAddCat(false)} style={{ flex:1 }}>Annuler</SecBtn>
            <PrimaryBtn onClick={addCat} disabled={!catForm.label} style={{ flex:2 }}>Créer</PrimaryBtn>
          </div>
        </Modal>
      )}

      {/* Add account modal */}
      {showAddAcc && (
        <Modal title="Nouveau compte" onClose={()=>setShowAddAcc(false)}>
          <Field label="Icône">
            <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
              {["💳","🏦","💰","🏧","💵","🪙","📈","🔐"].map(ic=><div key={ic} onClick={()=>setAccForm(p=>({...p,icon:ic}))} style={{ width:36, height:36, borderRadius:10, background:accForm.icon===ic?C.accent+"30":C.card2, border:`1px solid ${accForm.icon===ic?C.accent:C.border}`, display:"flex", alignItems:"center", justifyContent:"center", fontSize:18, cursor:"pointer" }}>{ic}</div>)}
            </div>
          </Field>
          <Field label="Nom"><TextInput value={accForm.label} onChange={e=>setAccForm(p=>({...p,label:e.target.value}))} placeholder="Ex: Compte courant"/></Field>
          <Field label={`Solde actuel (${profile.currency||"€"})`}><TextInput type="number" value={accForm.balance} onChange={e=>setAccForm(p=>({...p,balance:e.target.value}))} placeholder="0"/></Field>
          <div style={{ display:"flex", gap:10 }}>
            <SecBtn onClick={()=>setShowAddAcc(false)} style={{ flex:1 }}>Annuler</SecBtn>
            <PrimaryBtn onClick={addAcc} disabled={!accForm.label} style={{ flex:2 }}>Ajouter</PrimaryBtn>
          </div>
        </Modal>
      )}

      {/* Confirm reset */}
      {showConfirmReset && (
        <Modal title="⚠️ Confirmer la réinitialisation" onClose={()=>setShowConfirmReset(false)}>
          <div style={{ fontSize:13, color:C.muted, marginBottom:20, lineHeight:1.7 }}>Toutes vos données (transactions, objectifs, comptes, profil) seront supprimées. Cette action est irréversible.</div>
          <div style={{ display:"flex", gap:10 }}>
            <SecBtn onClick={()=>setShowConfirmReset(false)} style={{ flex:1 }}>Annuler</SecBtn>
            <button onClick={()=>{ setShowConfirmReset(false); onReset(); }} style={{ flex:2, background:C.accent3, color:"#fff", border:"none", borderRadius:12, padding:12, fontSize:14, fontWeight:800, cursor:"pointer" }}>Tout supprimer</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

// ─── APP ROOT ─────────────────────────────────────────────────
const NAV = [
  {id:"dashboard", icon:"🏠", label:"Accueil"},
  {id:"expenses",  icon:"📊", label:"Dépenses"},
  {id:"forecast",  icon:"📈", label:"Prévisions"},
  {id:"goals",     icon:"🎯", label:"Objectifs"},
  {id:"settings",  icon:"⚙️", label:"Réglages"},
];

function App() {
  const [state, setState] = useState(null);
  const [screen, setScreen] = useState("dashboard");

  useEffect(()=>{
    const saved = loadState();
    if(saved) setState(saved);
  },[]);

  useEffect(()=>{
    if(state) saveState(state);
  },[state]);

  function handleOnboarding(initialState) {
    setState(initialState);
    setScreen("dashboard");
  }

  function handleUpdate(patch) {
    setState(p=>({ ...p, ...patch }));
  }

  function handleReset() {
    localStorage.removeItem(STORE_KEY);
    setState(null);
    setScreen("dashboard");
  }

  if(!state) return <Onboarding onDone={handleOnboarding}/>;

  return (
    <div style={{ background:C.bg, minHeight:"100vh", maxWidth:430, margin:"0 auto", position:"relative", fontFamily:"-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif", color:C.text }}>
      <div style={{ overflowY:"auto", height:"100vh", paddingBottom:70 }}>
        {screen==="dashboard" && <Dashboard state={state} onNav={setScreen} onUpdate={handleUpdate}/>}
        {screen==="expenses"  && <Expenses  state={state} onUpdate={handleUpdate}/>}
        {screen==="forecast"  && <Forecast  state={state}/>}
        {screen==="goals"     && <Goals     state={state} onUpdate={handleUpdate}/>}
        {screen==="settings"  && <Settings  state={state} onUpdate={handleUpdate} onReset={handleReset}/>}
      </div>

      <div style={{ position:"fixed", bottom:0, left:"50%", transform:"translateX(-50%)", width:"100%", maxWidth:430, background:C.surface, borderTop:`1px solid ${C.border}`, display:"flex", paddingBottom:16, paddingTop:8, zIndex:100 }}>
        {NAV.map(item=>(
          <div key={item.id} onClick={()=>setScreen(item.id)} style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", gap:3, cursor:"pointer", opacity:screen===item.id?1:0.35, transition:"opacity .15s" }}>
            <span style={{ fontSize:19, filter:screen===item.id?`drop-shadow(0 0 5px ${C.accent})`:"none" }}>{item.icon}</span>
            {screen===item.id
              ? <div style={{ width:4, height:4, borderRadius:"50%", background:C.accent }}/>
              : <span style={{ fontSize:8, color:C.muted }}>{item.label}</span>}
          </div>
        ))}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App));
</script>
</body>
</html>
