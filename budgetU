<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>BudgetU – Mon Budget Étudiant</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%;background:#0a0b10}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#f0f2f8;overscroll-behavior:none}
  #root{height:100%}
  input,select,textarea{outline:none;font-family:inherit}
  button{font-family:inherit;cursor:pointer}
  ::-webkit-scrollbar{width:3px}
  ::-webkit-scrollbar-thumb{background:#252a38;border-radius:99px}
  input[type=range]{-webkit-appearance:none;height:4px;border-radius:99px;background:#252a38}
  input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;cursor:pointer}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect, useCallback } = React;

// ─── THEME ────────────────────────────────────────────────────
const C = {
  bg:"#0a0b10", surface:"#0d0f14", card:"#13161f", card2:"#181c28",
  border:"#1e2235", border2:"#252a3a",
  accent:"#c8f55a", accent2:"#5af5b8", accent3:"#f55a8f", accent4:"#f5a85a",
  purple:"#a78bfa", blue:"#38bdf8",
  text:"#f0f2f8", muted:"#6b7280",
};

// ─── DEFAULT CATEGORIES (user can edit) ───────────────────────
const DEFAULT_CATS = [
  { id:"loyer",        label:"Loyer",        icon:"🏠", color:C.accent,   budget:500 },
  { id:"alimentation", label:"Alimentation", icon:"🍔", color:C.accent3,  budget:300 },
  { id:"transport",    label:"Transport",    icon:"🚌", color:C.accent2,  budget:100 },
  { id:"loisirs",      label:"Loisirs",      icon:"🎉", color:C.accent4,  budget:150 },
  { id:"abonnements",  label:"Abonnements",  icon:"📱", color:C.purple,   budget:80  },
  { id:"sante",        label:"Santé",        icon:"💊", color:C.blue,     budget:60  },
  { id:"autres",       label:"Autres",       icon:"📦", color:C.muted,    budget:100 },
];

const KEYWORDS = {
  alimentation:["lidl","aldi","carrefour","monoprix","mcdo","mcdonald","burger","pizza","resto","restaurant","café","sushi","kebab","franprix","leclerc","boulangerie","supermarché"],
  transport:["ratp","sncf","metro","bus","uber","taxi","blablacar","navigo","train","vélib","trottinette","lime","bolt"],
  loyer:["loyer","rent","charges","edf","eau","gaz","electricité","internet","sfr","orange","free","bouygues"],
  loisirs:["netflix","cinema","concert","bar","club","jeux","steam","amazon","fnac","théâtre","spotify"],
  abonnements:["abonnement","subscription","premium","apple","google","youtube","disney","canal"],
  sante:["pharmacie","médecin","dentiste","hopital","clinique","mutuelle","opticien"],
};

function autoClassify(name, cats) {
  const l = name.toLowerCase();
  for (const [catId, words] of Object.entries(KEYWORDS))
    if (words.some(w => l.includes(w)) && cats.find(c => c.id === catId)) return catId;
  return "autres";
}

const PALETTE = ["#c8f55a","#5af5b8","#f55a8f","#f5a85a","#a78bfa","#38bdf8","#fb923c","#f472b6","#34d399","#60a5fa"];
const ICONS_CAT = ["🏠","🍔","🚌","🎉","📱","💊","📦","🛒","✈️","🎓","💻","🎸","🚗","👗","🏋️","🐾","🎮","☕"];
const ICONS_GOAL = ["🎯","✈️","🚗","🏠","💻","🛡️","💍","🎓","🌴","💪","🎸","📚","🏖️","🎿","🚢","💎"];

// ─── STORAGE ──────────────────────────────────────────────────
const STORE_KEY = "budgetu_v1";
function loadState() {
  try {
    const raw = localStorage.getItem(STORE_KEY);
    return raw ? JSON.parse(raw) : null;
  } catch { return null; }
}
function saveState(state) {
  try { localStorage.setItem(STORE_KEY, JSON.stringify(state)); } catch {}
}

// ─── UI ATOMS ─────────────────────────────────────────────────
function Card({ children, style={}, onClick }) {
  return <div onClick={onClick} style={{ background:C.card, border:`1px solid ${C.border}`, borderRadius:16, padding:16, cursor:onClick?"pointer":"default", ...style }}>{children}</div>;
}
function Badge({ children, color=C.accent }) {
  return <span style={{ background:color+"20", border:`1px solid ${color}44`, color, borderRadius:99, padding:"2px 10px", fontSize:11, fontWeight:700, whiteSpace:"nowrap" }}>{children}</span>;
}
function ProgressBar({ value, max, color=C.accent, height=6 }) {
  const pct = Math.min(100, Math.max(0, max>0?(value/max)*100:0));
  return (
    <div style={{ height, background:C.border2, borderRadius:99, overflow:"hidden" }}>
      <div style={{ height:"100%", width:`${pct}%`, background:pct>=100?C.accent3:pct>=80?C.accent4:color, borderRadius:99, transition:"width .4s ease" }}/>
    </div>
  );
}
function Modal({ title, onClose, children }) {
  return (
    <div style={{ position:"fixed", inset:0, background:"rgba(0,0,0,0.8)", zIndex:300, display:"flex", alignItems:"flex-end" }} onClick={onClose}>
      <div onClick={e=>e.stopPropagation()} style={{ background:C.card, borderRadius:"22px 22px 0 0", padding:24, width:"100%", border:`1px solid ${C.border}`, maxHeight:"90vh", overflowY:"auto" }}>
        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:18 }}>
          <div style={{ fontSize:17, fontWeight:800 }}>{title}</div>
          <div onClick={onClose} style={{ width:30, height:30, borderRadius:"50%", background:C.card2, display:"flex", alignItems:"center", justifyContent:"center", cursor:"pointer", color:C.muted, fontSize:14 }}>✕</div>
        </div>
        {children}
      </div>
    </div>
  );
}
function Field({ label, hint, children }) {
  return (
    <div style={{ marginBottom:14 }}>
      {label && <div style={{ fontSize:11, color:C.muted, marginBottom:4 }}>{label}</div>}
      {hint  && <div style={{ fontSize:10, color:C.muted, marginBottom:6, opacity:.7 }}>{hint}</div>}
      {children}
    </div>
  );
}
function TextInput({ value, onChange, placeholder, type="text", style={} }) {
  return <input type={type} value={value} onChange={onChange} placeholder={placeholder}
    style={{ width:"100%", background:C.card2, border:`1px solid ${C.border}`, color:C.text, borderRadius:10, padding:"11px 13px", fontSize:14, ...style }}/>;
}
function PrimaryBtn({ children, onClick, style={}, disabled=false }) {
  return <button onClick={onClick} disabled={disabled} style={{ background:disabled?C.border:C.accent, color:"#0d0f14", borderRadius:12, padding:"12px 20px", fontSize:14, fontWeight:800, border:"none", opacity:disabled?.5:1, width:"100%", ...style }}>{children}</button>;
}
function SecBtn({ children, onClick, style={} }) {
  return <button onClick={onClick} style={{ background:C.card2, color:C.muted, borderRadius:12, padding:"11px 16px", fontSize:14, border:`1px solid ${C.border}`, ...style }}>{children}</button>;
}

function Donut({ data, size=80, label="" }) {
  const total = data.reduce((s,d)=>s+d.value,0)||1;
  const r=size*.35, cx=size/2, cy=size/2, circ=2*Math.PI*r;
  let off=0;
  const slices=data.map(d=>{
    const dash=(d.value/total)*circ, gap=circ-dash, s={...d,dash,gap,off:-off};
    off+=dash; return s;
  });
  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} style={{flexShrink:0}}>
      <circle cx={cx} cy={cy} r={r} fill="none" stroke={C.border2} strokeWidth={size*.13}/>
      {slices.map((s,i)=>(
        <circle key={i} cx={cx} cy={cy} r={r} fill="none" stroke={s.color}
          strokeWidth={size*.13} strokeDasharray={`${s.dash} ${s.gap}`}
          strokeDashoffset={s.off} strokeLinecap="round"
          style={{transformOrigin:"center",transform:"rotate(-90deg)"}}/>
      ))}
      {label && <>
        <text x={cx} y={cy-4} textAnchor="middle" fill={C.text} fontFamily="sans-serif" fontSize={size*.13} fontWeight="800">{label}</text>
        <text x={cx} y={cy+10} textAnchor="middle" fill={C.muted} fontFamily="sans-serif" fontSize={size*.09}>dépensé</text>
      </>}
    </svg>
  );
}

function LineChart({ data, color=C.accent, height=70 }) {
  if(!data||data.length<2) return <div style={{ height, display:"flex", alignItems:"center", justifyContent:"center", color:C.muted, fontSize:11 }}>Pas encore assez de données</div>;
  const vals=data.map(d=>d.value);
  const max=Math.max(...vals)||1, min=Math.min(...vals), range=max-min||1;
  const W=300, H=height, p=10;
  const pts=data.map((d,i)=>({ x:p+(i/(data.length-1))*(W-p*2), y:H-p-((d.value-min)/range)*(H-p*2) }));
  const path=pts.map((pt,i)=>`${i===0?"M":"L"}${pt.x},${pt.y}`).join(" ");
  const area=`${path} L${pts[pts.length-1].x},${H} L${pts[0].x},${H} Z`;
  return (
    <svg width="100%" viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none">
      <defs><linearGradient id="lg" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stopColor={color} stopOpacity=".25"/>
        <stop offset="100%" stopColor={color} stopOpacity="0"/>
      </linearGradient></defs>
      <path d={area} fill="url(#lg)"/>
      <path d={path} fill="none" stroke={color} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
      {pts.map((pt,i)=><circle key={i} cx={pt.x} cy={pt.y} r="3" fill={color}/>)}
    </svg>
  );
}

// ─── ONBOARDING ───────────────────────────────────────────────
function Onboarding({ onDone }) {
  const [step, setStep] = useState(0);
  const [profile, setProfile] = useState({ name:"", income:"", currency:"€" });
  const [accounts, setAccounts] = useState([{ id:Date.now(), label:"Compte Courant", icon:"💳", balance:"", color:C.accent }]);
  const [cats, setCats] = useState(DEFAULT_CATS);
  const [editBudgetIdx, setEditBudgetIdx] = useState(null);

  const STEPS = ["Bienvenue", "Revenus", "Comptes", "Budgets", "Prêt !"];

  function addAccount() {
    setAccounts(p=>[...p,{ id:Date.now(), label:"", icon:"🏦", balance:"", color:C.accent2 }]);
  }
  function removeAccount(id) { setAccounts(p=>p.filter(a=>a.id!==id)); }
  function updateAccount(id, key, val) { setAccounts(p=>p.map(a=>a.id===id?{...a,[key]:val}:a)); }
  function updateCatBudget(id, val) { setCats(p=>p.map(c=>c.id===id?{...c,budget:parseFloat(val)||0}:c)); }

  function finish() {
    onDone({
      profile,
      accounts: accounts.filter(a=>a.label).map(a=>({ ...a, balance:parseFloat(a.balance)||0 })),
      categories: cats,
      transactions: [],
      goals: [],
      history: {},
    });
  }

  const canNext = [
    profile.name.trim().length > 0,
    profile.income.trim().length > 0,
    accounts.some(a=>a.label.trim()),
    true,
    true,
  ][step];

  return (
    <div style={{ minHeight:"100vh", background:C.bg, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", padding:24 }}>
      {/* Progress */}
      <div style={{ width:"100%", maxWidth:400, marginBottom:32 }}>
        <div style={{ display:"flex", justifyContent:"space-between", marginBottom:10 }}>
          {STEPS.map((s,i)=>(
            <div key={i} style={{ display:"flex", flexDirection:"column", alignItems:"center", gap:4 }}>
              <div style={{ width:28, height:28, borderRadius:"50%", background:i<=step?C.accent:C.border2, color:i<=step?"#0d0f14":C.muted, display:"flex", alignItems:"center", justifyContent:"center", fontSize:12, fontWeight:800, transition:"background .3s" }}>{i<step?"✓":i+1}</div>
              <div style={{ fontSize:9, color:i===step?C.accent:C.muted, display:step===i?"block":"none" }}>{s}</div>
            </div>
          ))}
        </div>
        <div style={{ height:3, background:C.border2, borderRadius:99 }}>
          <div style={{ height:"100%", width:`${(step/4)*100}%`, background:C.accent, borderRadius:99, transition:"width .4s ease" }}/>
        </div>
      </div>

      <div style={{ width:"100%", maxWidth:400 }}>
        {/* STEP 0 — Welcome */}
        {step===0 && (
          <div style={{ textAlign:"center" }}>
            <div style={{ fontSize:52, marginBottom:16 }}>🎓</div>
            <div style={{ fontSize:26, fontWeight:800, marginBottom:8 }}>Bienvenue sur BudgetU</div>
            <div style={{ fontSize:14, color:C.muted, marginBottom:32, lineHeight:1.6 }}>Votre assistant budget étudiant intelligent. Configurons votre espace en quelques étapes.</div>
            <Field label="Votre prénom">
              <TextInput value={profile.name} onChange={e=>setProfile(p=>({...p,name:e.target.value}))} placeholder="Ex: Sophie"/>
            </Field>
            <Field label="Devise">
              <select value={profile.currency} onChange={e=>setProfile(p=>({...p,currency:e.target.value}))} style={{ width:"100%", background:C.card2, border:`1px solid ${C.border}`, color:C.text, borderRadius:10, padding:"11px 13px", fontSize:14 }}>
                {["€","$","£","CHF","MAD","XOF","DZD","TND"].map(c=><option key={c} value={c}>{c}</option>)}
              </select>
            </Field>
          </div>
        )}

        {/* STEP 1 — Income */}
        {step===1 && (
          <div>
            <div style={{ fontSize:22, fontWeight:800, marginBottom:6 }}>💰 Vos revenus mensuels</div>
            <div style={{ fontSize:13, color:C.muted, marginBottom:20 }}>Indiquez le total de vos rentrées d'argent par mois (bourse, job, aide famille…)</div>
            <Field label={`Revenu mensuel total (${profile.currency})`}>
              <TextInput type="number" value={profile.income} onChange={e=>setProfile(p=>({...p,income:e.target.value}))} placeholder="Ex: 1200"/>
            </Field>
            <div style={{ background:C.card2, border:`1px solid ${C.border}`, borderRadius:12, padding:14, marginTop:8 }}>
              <div style={{ fontSize:12, color:C.muted, lineHeight:1.6 }}>
                💡 Incluez : salaire, bourse CROUS, aide parentale, APL, jobs étudiants…
              </div>
            </div>
          </div>
        )}

        {/* STEP 2 — Accounts */}
        {step===2 && (
          <div>
            <div style={{ fontSize:22, fontWeight:800, marginBottom:6 }}>🏦 Vos comptes</div>
            <div style={{ fontSize:13, color:C.muted, marginBottom:20 }}>Ajoutez vos comptes bancaires pour un suivi complet.</div>
            <div style={{ display:"flex", flexDirection:"column", gap:10, marginBottom:12 }}>
              {accounts.map((a,i)=>(
                <Card key={a.id} style={{ padding:12 }}>
                  <div style={{ display:"flex", gap:8, alignItems:"center", marginBottom:8 }}>
                    <div style={{ fontSize:20 }}>{a.icon}</div>
                    <div style={{ flex:1, fontSize:13, fontWeight:600 }}>{a.label||"Nouveau compte"}</div>
                    {accounts.length>1 && <span onClick={()=>removeAccount(a.id)} style={{ color:C.accent3, cursor:"pointer", fontSize:13 }}>✕</span>}
                  </div>
                  <TextInput value={a.label} onChange={e=>updateAccount(a.id,"label",e.target.value)} placeholder="Nom du compte" style={{ marginBottom:8 }}/>
                  <TextInput type="number" value={a.balance} onChange={e=>updateAccount(a.id,"balance",e.target.value)} placeholder={`Solde actuel (${profile.currency})`}/>
                </Card>
              ))}
            </div>
            <button onClick={addAccount} style={{ width:"100%", background:"transparent", border:`1px dashed ${C.border2}`, color:C.muted, borderRadius:12, padding:12, fontSize:13, cursor:"pointer" }}>+ Ajouter un compte</button>
          </div>
        )}

        {/* STEP 3 — Budgets */}
        {step===3 && (
          <div>
            <div style={{ fontSize:22, fontWeight:800, marginBottom:6 }}>🎯 Vos budgets</div>
            <div style={{ fontSize:13, color:C.muted, marginBottom:20 }}>Définissez un plafond mensuel pour chaque catégorie.</div>
            <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
              {cats.map(c=>(
                <div key={c.id} style={{ background:C.card2, border:`1px solid ${C.border}`, borderRadius:12, padding:"10px 14px", display:"flex", alignItems:"center", gap:10 }}>
                  <span style={{ fontSize:18 }}>{c.icon}</span>
                  <span style={{ flex:1, fontSize:13 }}>{c.label}</span>
                  <div style={{ display:"flex", alignItems:"center", gap:6 }}>
                    <span style={{ fontSize:12, color:C.muted }}>{profile.currency}</span>
                    <input type="number" value={c.budget} onChange={e=>updateCatBudget(c.id,e.target.value)}
                      style={{ width:70, background:C.card, border:`1px solid ${C.border}`, color:C.accent, borderRadius:8, padding:"5px 8px", fontSize:13, fontWeight:700, textAlign:"right" }}/>
                  </div>
                </div>
              ))}
            </div>
            <div style={{ fontSize:11, color:C.muted, marginTop:12, textAlign:"center" }}>
              Budget total : <strong style={{ color:C.accent }}>{profile.currency}{cats.reduce((s,c)=>s+c.budget,0)}</strong> / mois
            </div>
          </div>
        )}

        {/* STEP 4 — Ready */}
        {step===4 && (
          <div style={{ textAlign:"center" }}>
            <div style={{ fontSize:56, marginBottom:16 }}>🚀</div>
            <div style={{ fontSize:24, fontWeight:800, marginBottom:8 }}>Tout est prêt, {profile.name} !</div>
            <div style={{ fontSize:14, color:C.muted, marginBottom:28, lineHeight:1.7 }}>
              Votre espace est configuré. Commencez à ajouter vos dépenses pour obtenir des insights personnalisés.
            </div>
            <div style={{ display:"flex", flexDirection:"column", gap:8, textAlign:"left", marginBottom:24 }}>
              {[
                [`${profile.currency}${parseFloat(profile.income)||0}/mois`, "Revenu configuré"],
                [`${accounts.filter(a=>a.label).length} compte(s)`, "Comptes ajoutés"],
                [`${cats.length} catégories`, "Budgets définis"],
              ].map(([val,lbl])=>(
                <div key={lbl} style={{ background:C.card2, borderRadius:12, padding:"10px 14px", display:"flex", justifyContent:"space-between" }}>
                  <span style={{ fontSize:13, color:C.muted }}>{lbl}</span>
                  <span style={{ fontSize:13, fontWeight:700, color:C.accent }}>{val}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Navigation */}
        <div style={{ display:"flex", gap:10, marginTop:24 }}>
          {step>0 && <SecBtn onClick={()=>setStep(p=>p-1)} style={{ flex:1 }}>← Retour</SecBtn>}
          {step<4
            ? <PrimaryBtn onClick={()=>setStep(p=>p+1)} disabled={!canNext} style={{ flex:2 }}>Continuer →</PrimaryBtn>
            : <PrimaryBtn onClick={finish} style={{ flex:2 }}>Commencer 🎉</PrimaryBtn>
          }
        </div>
      </div>
    </div>
  );
}

// ─── DASHBOARD ────────────────────────────────────────────────
function Dashboard({ state, onNav, onUpdate }) {
  const { profile, transactions, categories, accounts, goals } = state;
  const currency = profile.currency || "€";
  const income = parseFloat(profile.income)||0;
  const now = new Date();
  const monthKey = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,"0")}`;

  const monthTx = transactions.filter(t=>t.date.startsWith(monthKey));
  const expenses = monthTx.filter(t=>t.amount<0);
  const totalSpent = Math.abs(expenses.reduce((s,t)=>s+t.amount,0));
  const totalBudget = categories.reduce((s,c)=>s+c.budget,0);
  const totalBalance = accounts.reduce((s,a)=>s+a.balance,0);
  const savingsRate = income>0?Math.max(0,Math.round(((income-totalSpent)/income)*100)):0;

  const byCategory = {};
  expenses.forEach(t=>{ byCategory[t.category]=(byCategory[t.category]||0)+Math.abs(t.amount); });
  const donutData = Object.entries(byCategory).map(([id,val])=>({ color:categories.find(c=>c.id===id)?.color||C.muted, value:val }));
  const top5 = Object.entries(byCategory).sort((a,b)=>b[1]-a[1]).slice(0,5);

  // Alerts
  const alerts = [];
  Object.entries(byCategory).forEach(([catId,spent])=>{
    const cat = categories.find(c=>c.id===catId);
    if(!cat||!cat.budget) return;
    const pct = spent/cat.budget;
    if(pct>=0.8) alerts.push({ key:catId, icon:pct>=1?"🚨":"⚠️", color:pct>=1?C.accent3:C.accent4,
      msg:`${cat.icon} ${cat.label} : ${pct>=1?"Budget dépassé !":"80% atteint"} (${currency}${spent.toFixed(0)}/${currency}${cat.budget})` });
  });

  const [dismissed, setDismissed] = useState([]);
  const visible = alerts.filter(a=>!dismissed.includes(a.key));

  const recentTx = transactions.slice(0,5);

  return (
    <div style={{ padding:"0 0 80px" }}>
      <div style={{ padding:"20px 16px 12px", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <div>
          <div style={{ fontSize:12, color:C.muted }}>Bonjour,</div>
          <div style={{ fontSize:22, fontWeight:800 }}>{profile.name} 👋</div>
        </div>
        <div style={{ textAlign:"right" }}>
          <div style={{ fontSize:10, color:C.muted }}>Solde total</div>
          <div style={{ fontSize:20, fontWeight:800, color:C.accent }}>{currency}{totalBalance.toFixed(0)}</div>
        </div>
      </div>

      <div style={{ padding:"0 14px", display:"flex", flexDirection:"column", gap:12 }}>
        {/* Alerts */}
        {visible.length>0 && (
          <div style={{ display:"flex", flexDirection:"column", gap:6 }}>
            {visible.map(a=>(
              <div key={a.key} style={{ background:a.color+"18", border:`1px solid ${a.color}44`, borderRadius:12, padding:"10px 14px", display:"flex", alignItems:"center", gap:10 }}>
                <span style={{ fontSize:17 }}>{a.icon}</span>
                <span style={{ flex:1, fontSize:12 }}>{a.msg}</span>
                <span onClick={()=>setDismissed(p=>[...p,a.key])} style={{ cursor:"pointer", color:C.muted, fontSize:13, padding:"0 4px" }}>✕</span>
              </div>
            ))}
          </div>
        )}

        {/* Accounts */}
        {accounts.length>0 ? (
          <div style={{ display:"flex", gap:8, overflowX:"auto", paddingBottom:4 }}>
