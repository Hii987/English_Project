        {/* Top 5 */}
        {top5.length>0 && (
          <Card>
            <div style={{ fontSize:13, fontWeight:700, marginBottom:12 }}>🏆 Top dépenses</div>
            <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
              {top5.map(([catId,val])=>{
